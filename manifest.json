{
  "manifest_version": 3,
  "name": "WebPilot Pro",
  "version": "4.0.0",
  "description": "Cache clear, analysis, SEO, images, copy mode, links, AI detector & search — by Adeel dev.",
  "author": "Adeel dev",
  "permissions": [
    "browsingData",
    "tabs",
    "activeTab",
    "scripting",
    "cookies",
    "storage",
    "downloads",
    "clipboardWrite",
    "clipboardRead"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "My Urban Limos — by Adeel dev"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
